{
    "name": "PintOS Ubuntu 14.04",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-extension-pack"
            ]
        }
    },
    "remoteUser": "root",
    "workspaceFolder": "/workspaces/pintos-project",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/pintos-project,type=bind",
    "postCreateCommand": "echo 'Container is ready.'"
}